# =============================================================================
# SoulSathiya Platform - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# -----------------------------------------------------------------------------
# Python / FastAPI Backend
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
parts/
var/
wheels/
*.manifest
*.spec

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Python tools
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.pytype/
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# Node / React Frontend
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Build output
frontend/build/
build/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
*.mongodump
dump/
mongodump/

# -----------------------------------------------------------------------------
# Logs & Debug
# -----------------------------------------------------------------------------
logs/
*.log
debug.log

# -----------------------------------------------------------------------------
# Docker (if used later)
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
.parcel-cache/
coverage/
