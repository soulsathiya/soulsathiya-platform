# =============================================================================
# SoulSathiya Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (MongoDB)
# -----------------------------------------------------------------------------
# MongoDB connection string (required)
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (required)
DB_NAME=soulsathiya

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins (default: * in dev)
# In production, set this to your actual frontend domain(s)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# -----------------------------------------------------------------------------
# Admin Credentials
# -----------------------------------------------------------------------------
# Initial admin account email (used by admin_service for bootstrap)
ADMIN_EMAIL=admin@soulsathiya.com

# Initial admin account password
ADMIN_PASSWORD=your_secure_admin_password_here

# Whether admin must change password on first login (default: true)
ADMIN_REQUIRE_PASSWORD_CHANGE=true
# One-time setup token required to call /api/admin/setup (unauthenticated endpoint).
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to DISABLE the setup endpoint entirely (recommended once admin is created).
ADMIN_SETUP_TOKEN=your_one_time_setup_token_here

# -----------------------------------------------------------------------------
# Razorpay Payment Gateway (used by boost_service and subscriptions)
# -----------------------------------------------------------------------------
# Razorpay API Key ID (get from https://dashboard.razorpay.com)
# IMPORTANT: Use test keys (rzp_test_...) in development only.
#            In production, set this to a live key (rzp_live_...).
#            Razorpay displays a "Test Mode" banner in their checkout widget
#            whenever a test key is used, which is visible to end users.
RAZORPAY_KEY_ID=rzp_test_placeholder

# Razorpay API Key Secret
# Must match the key above (test secret ↔ test key, live secret ↔ live key).
RAZORPAY_KEY_SECRET=placeholder_secret

# -----------------------------------------------------------------------------
# Server Configuration (optional)
# -----------------------------------------------------------------------------
# Port for the backend server (default: 8000)
PORT=8000

# Set to "production" in prod to enable Secure+SameSite=None cookies (requires HTTPS)
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# URL to your OAuth session resolver endpoint (handles Google OAuth token exchange)
# Replace this with your own OAuth provider endpoint or use the default dev one
GOOGLE_OAUTH_SESSION_URL=https://demobackend.emergentagent.com/auth/v1/env/oauth/session-data

# -----------------------------------------------------------------------------
# Email — Resend (Issue #2 Email Verification & Issue #3 Password Reset)
# -----------------------------------------------------------------------------
# Resend API key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# "From" address shown in emails (must be a verified domain in Resend)
EMAIL_FROM=SoulSathiya <noreply@yourdomain.com>

# Public URL of the frontend — used to build clickable links inside emails
# In production set this to your Vercel / custom domain URL
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AWS S3 (Photo Storage)
# -----------------------------------------------------------------------------
# AWS credentials for S3 photo uploads (required for photo upload feature)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
# S3 bucket name (must be created in your AWS account with public-read policy)
S3_BUCKET_NAME=soulsathiya-photos
